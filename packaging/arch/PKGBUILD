# Maintainer: Samuel B <samuelb@users.noreply.github.com>
#
# The committed copy of this file is a generic VCS build: latest git state,
# version derived from `git describe`, checksum SKIP. The release pipeline
# (scripts/stage-arch-release.sh) renders a pinned copy -- fixed pkgver,
# release-tarball source, real checksum -- and attaches it to each GitHub
# release.
pkgname=somad
_binname=soma
pkgver=0.13.0
pkgrel=1
pkgdesc='A client for streaming SomaFM radio channels'
arch=('x86_64' 'aarch64')
url='https://github.com/samuelb/somad'
license=('MIT')
depends=('alsa-lib' 'ca-certificates')
makedepends=('go' 'git')
source=("${pkgname}::git+${url}.git")
sha256sums=('SKIP')

pkgver() {
  cd "${pkgname}"
  git describe --long --tags | sed 's/^v//;s/\([^-]*-g\)/r\1/;s/-/./g'
}

build() {
  cd "${pkgname}"
  export CGO_ENABLED=1
  export GOFLAGS="-buildvcs=false -mod=vendor"
  go build \
    -ldflags "-s -w -X main.version=v${pkgver} -X main.commit=arch -X main.date=$(date -u +%Y-%m-%dT%H:%M:%SZ)" \
    -o "${_binname}" \
    ./cmd/soma
}

check() {
  cd "${pkgname}"
  export CGO_ENABLED=1
  export GOFLAGS="-buildvcs=false -mod=vendor"
  go test ./...
}

package() {
  cd "${pkgname}"
  install -Dm755 "${_binname}" "${pkgdir}/usr/bin/${_binname}"
  install -Dm644 LICENSE "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
  install -Dm644 README.md "${pkgdir}/usr/share/doc/${pkgname}/README.md"
  install -Dm644 cmd/soma/completions/soma.bash "${pkgdir}/usr/share/bash-completion/completions/${_binname}"
  install -Dm644 cmd/soma/completions/soma.zsh "${pkgdir}/usr/share/zsh/site-functions/_${_binname}"
}
