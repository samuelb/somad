# Maintainer: Samuel B <samuelb@users.noreply.github.com>
pkgname=somatui
pkgver=0.9.0
pkgrel=1
pkgdesc='Terminal UI client for streaming SomaFM radio channels'
arch=('x86_64' 'aarch64')
url='https://github.com/samuelb/somatui'
license=('MIT')
depends=('alsa-lib' 'ca-certificates')
makedepends=('go')
source=("${pkgname}-${pkgver}.tar.gz::${url}/archive/refs/tags/v${pkgver}.tar.gz")
sha256sums=('SKIP')

build() {
  cd "${pkgname}-${pkgver}"
  export CGO_ENABLED=1
  export GOFLAGS="-buildvcs=false -mod=vendor"
  go build \
    -ldflags "-s -w -X main.version=v${pkgver} -X main.commit=aur -X main.date=$(date -u +%Y-%m-%dT%H:%M:%SZ)" \
    -o "${pkgname}" \
    ./cmd/somatui
}

check() {
  cd "${pkgname}-${pkgver}"
  export CGO_ENABLED=1
  export GOFLAGS="-buildvcs=false -mod=vendor"
  go test ./...
}

package() {
  cd "${pkgname}-${pkgver}"
  install -Dm755 "${pkgname}" "${pkgdir}/usr/bin/${pkgname}"
  install -Dm644 LICENSE "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
  install -Dm644 README.md "${pkgdir}/usr/share/doc/${pkgname}/README.md"
}
